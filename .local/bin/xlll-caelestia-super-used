#!/usr/bin/env bash
set -u

STATE="/tmp/xlll-caelestia-super-used-${UID}"
NOW="$(date +%s%3N 2>/dev/null || python - <<'PY'
import time
print(int(time.time() * 1000))
PY
)"

echo "$NOW" > "$STATE"

(
    sleep 0.8
    if [ -f "$STATE" ]; then
        OLD="$(cat "$STATE" 2>/dev/null || true)"
        if [ "$OLD" = "$NOW" ]; then
            rm -f "$STATE"
        fi
    fi
) >/dev/null 2>&1 &
